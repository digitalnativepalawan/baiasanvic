# Supabase (Lovable Cloud) — required for site content, admin auth, storage, and bookings.
# These values are auto-injected on Lovable Cloud projects. Copy this file to
# `.env` when running locally against your own Supabase project.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-or-publishable-key"

# Optional — only used for `supabase-js` typings and Lovable tooling.
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Onyx Brain (optional — enables Onyx as AI concierge provider)
# Set these env vars in Lovable Cloud to connect the site to a live Onyx instance.
# Get the API key from your Onyx deployment's admin panel.
ONYX_BASE_URL="https://your-onyx-instance.com"
ONYX_API_KEY="your-onyx-api-key"
ONYX_RESORT_PERSONA_ID="1"
ONYX_OPERATIONS_API_SECRET="your-operations-secret"
ONYX_TIMEOUT_MS="30000"
